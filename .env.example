# DeepSeek (Phase 3 LLM adjudication)
DEEPSEEK_API_KEY=your_deepseek_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TEMPERATURE=0.1
DEEPSEEK_MAX_RETRIES=3

# OpenAI (Phase 2 embeddings)
OPENAI_API_KEY=your_openai_key_here

# Database
DATABASE_URL=postgresql://localhost:5432/arbit

# Phase 3 tuning
PHASE3_DATE_TOLERANCE_DAYS=30
PHASE3_ENTITY_MATCH_THRESHOLD=0.85
PHASE3_LLM_RATE_LIMIT_RPS=5
PHASE3_ENABLE_CACHE=false
